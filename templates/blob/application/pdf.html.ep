<%
  my $p = stash('blob_params');
  my $pdf_url = url_for($p->{rep_info}->url("raw/$p->{rev}/$p->{file}"));
%>

<div class="blob-pdf-container">
  <object class="blob-pdf-object" data="<%= $pdf_url %>" type="application/pdf">
    <p>
      Your browser does not support PDFs.
    </p>
  </object>
</div>
